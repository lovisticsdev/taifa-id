# TaifaID local environment example.
# Copy to .env for local use if your shell tooling loads .env files.
# Do not commit real credentials.

TAIFA_ID_SERVICE_NAME=taifa-id
TAIFA_ID_ENV=local

TAIFA_ID_HTTP_ADDR=:8080
TAIFA_ID_HTTP_READ_TIMEOUT=5s
TAIFA_ID_HTTP_WRITE_TIMEOUT=10s
TAIFA_ID_HTTP_IDLE_TIMEOUT=60s
TAIFA_ID_HTTP_SHUTDOWN_TIMEOUT=10s

# Local Docker PostgreSQL example:
TAIFA_ID_DATABASE_DSN=host=localhost port=5432 user=taifa password=taifa_dev_password dbname=taifa_id sslmode=disable

# AWS RDS PostgreSQL example:
# TAIFA_ID_DATABASE_DSN=postgres://taifa:Pass12345!@taifa-id-db.cr2y4ys2gexh.us-east-2.rds.amazonaws.com:5432/taifa_id?sslmode=require

TAIFA_ID_DATABASE_MIN_CONNS=1
TAIFA_ID_DATABASE_MAX_CONNS=5
TAIFA_ID_DATABASE_CONNECT_TIMEOUT=15s

TAIFA_ID_JWT_SECRET=replace-this-with-a-long-local-dev-secret-at-least-32-chars
TAIFA_ID_JWT_ISSUER=taifa-id
TAIFA_ID_JWT_AUDIENCE=taifa-republic
TAIFA_ID_JWT_TTL=1h

TAIFA_ID_SEED_PASSWORD=ExampleDevPass123!
TAIFA_ID_SEED_TIMEOUT=5m

TAIFA_ID_TEST_BASE_URL=http://localhost:8080
TAIFA_ID_TEST_USERNAME=clinician.seed
TAIFA_ID_TEST_PASSWORD=ExampleDevPass123!
TAIFA_ID_TEST_ORGANIZATION_ID=ORG-HP-CLINIC
TAIFA_ID_TEST_EXPECTED_ROLE=PROVIDER_CLINICIAN